<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Paysera Demo — Transfer</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #00c48c;
    --dark:  #0a0f1e;
    --card:  #111827;
    --border:#1f2d3d;
    --text:  #e2e8f0;
    --muted: #64748b;
    --red:   #ef4444;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--dark); color: var(--text); font-family: 'DM Mono', monospace; min-height: 100vh; }

  header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 1rem;
  }
  .logo { font-family: 'Syne', sans-serif; font-size: 1.6rem; font-weight: 800; color: var(--green); letter-spacing: -1px; }
  .logo span { color: var(--text); }

  .layout { display: grid; grid-template-columns: 1fr 1.4fr; gap: 2rem; padding: 2rem; max-width: 1200px; margin: 0 auto; }

  .card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 1.8rem; }
  .card h2 { font-family: 'Syne', sans-serif; font-size: 1.1rem; color: var(--green); margin-bottom: 1.4rem; letter-spacing: 1px; text-transform: uppercase; }

  /* Accounts */
  .account-item { display: flex; justify-content: space-between; align-items: center; padding: .9rem 1rem; border-radius: 10px; margin-bottom: .6rem; background: var(--dark); border: 1px solid var(--border); }
  .account-name { font-size: .85rem; color: var(--muted); }
  .account-bal { font-size: 1.1rem; font-weight: 500; color: var(--text); }
  .badge { font-size: .7rem; padding: .2rem .5rem; border-radius: 99px; background: #00c48c22; color: var(--green); border: 1px solid #00c48c44; }

  /* Form */
  label { display: block; font-size: .75rem; color: var(--muted); margin-bottom: .4rem; margin-top: 1rem; text-transform: uppercase; letter-spacing: .5px; }
  select, input[type=number] {
    width: 100%; padding: .75rem 1rem; border-radius: 10px;
    background: var(--dark); border: 1px solid var(--border);
    color: var(--text); font-family: 'DM Mono', monospace; font-size: .9rem;
    outline: none; transition: border .2s;
  }
  select:focus, input:focus { border-color: var(--green); }

  .arrow { text-align: center; padding: .6rem; color: var(--green); font-size: 1.4rem; }

  .btn {
    display: block; width: 100%; margin-top: 1.5rem;
    padding: .9rem; border-radius: 10px; border: none;
    background: var(--green); color: #000; font-family: 'Syne', sans-serif;
    font-size: 1rem; font-weight: 800; cursor: pointer; letter-spacing: .5px;
    transition: opacity .2s, transform .1s;
  }
  .btn:hover { opacity: .85; transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* Flash messages */
  .flash { padding: .8rem 1rem; border-radius: 10px; margin-bottom: 1rem; font-size: .85rem; }
  .flash.success { background: #00c48c22; border: 1px solid #00c48c44; color: var(--green); }
  .flash.error   { background: #ef444422; border: 1px solid #ef444444; color: var(--red); }

  /* Table */
  .tx-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
  .tx-table th { color: var(--muted); text-align: left; padding: .6rem .8rem; border-bottom: 1px solid var(--border); font-weight: 400; text-transform: uppercase; font-size: .7rem; letter-spacing: .5px; }
  .tx-table td { padding: .75rem .8rem; border-bottom: 1px solid #1a2233; }
  .tx-table tr:last-child td { border-bottom: none; }
  .tx-table tr:hover td { background: #ffffff05; }
  .amount-cell { color: var(--green); font-weight: 500; }
  .date-cell { color: var(--muted); font-size: .75rem; }
  .empty { text-align: center; padding: 2rem; color: var(--muted); }

  @media (max-width: 768px) { .layout { grid-template-columns: 1fr; } }
</style>
</head>
<body>

<header>
  <div class="logo">Pay<span>sera</span></div>
  <span style="color:var(--muted);font-size:.85rem;">/ Transaction Demo</span>
</header>

<div class="layout">

  {# LEFT COLUMN #}
  <div>
    {# Flash messages #}
    {% for msg in app.flashes('success') %}
      <div class="flash success">✓ {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
      <div class="flash error">✗ {{ msg }}</div>
    {% endfor %}

    {# Accounts #}
    <div class="card" style="margin-bottom:1.5rem">
      <h2>Accounts</h2>
      {% for account in accounts %}
        <div class="account-item">
          <div>
            <div>{{ account.name }}</div>
            <div class="account-name">ID #{{ account.id }}</div>
          </div>
          <div style="text-align:right">
            <div class="account-bal">{{ account.balance }}</div>
            <span class="badge">{{ account.currency }}</span>
          </div>
        </div>
      {% endfor %}
    </div>

    {# Transfer Form #}
    <div class="card">
      <h2>New Transfer</h2>
      <form action="{{ path('app_transfer') }}" method="POST">
        <label>From Account</label>
        <select name="from_account" required>
          <option value="">— select sender —</option>
          {% for account in accounts %}
            <option value="{{ account.id }}">{{ account.name }} ({{ account.balance }} {{ account.currency }})</option>
          {% endfor %}
        </select>

        <div class="arrow">↓</div>

        <label>To Account</label>
        <select name="to_account" required>
          <option value="">— select recipient —</option>
          {% for account in accounts %}
            <option value="{{ account.id }}">{{ account.name }}</option>
          {% endfor %}
        </select>

        <label>Amount</label>
        <input type="number" name="amount" step="0.01" min="0.01" placeholder="0.00" required>

        <button type="submit" class="btn">Send Transfer →</button>
      </form>
    </div>
  </div>

  {# RIGHT COLUMN — Transaction History #}
  <div class="card">
    <h2>Transaction History</h2>
    {% if transactions is empty %}
      <div class="empty">No transactions yet.</div>
    {% else %}
      <table class="tx-table">
        <thead>
          <tr>
            <th>#</th>
            <th>From</th>
            <th>To</th>
            <th>Amount</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          {% for tx in transactions %}
            <tr>
              <td style="color:var(--muted)">{{ tx.id }}</td>
              <td>{{ tx.fromAccount.name }}</td>
              <td>{{ tx.toAccount.name }}</td>
              <td class="amount-cell">{{ tx.amount }} {{ tx.fromAccount.currency }}</td>
              <td class="date-cell">{{ tx.createdAt|date('d M Y H:i') }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% endif %}
  </div>

</div>
</body>
</html>